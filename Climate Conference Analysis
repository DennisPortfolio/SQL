SQL queries 

-- 1.  First it's important to know which events are drawing the most vip attendance

SELECT COUNT(vips.member_id) AS vip_count , events.event_id, events.event_name
FROM vips
LEFT JOIN events
ON vips.event = events.event_id
GROUP BY events.event_id , events.event_name
ORDER BY vip_count DESC
;
-- 2. [] Let's see who is going to be providing valuable insight to others and information that can be used for them to meet up and discuss notes

SELECT speaker.last_name AS Speaker , counsel.last_name AS Counselor
FROM vips AS speaker
INNER JOIN vips AS counsel
ON speaker.member_id = counsel.provides_feedback_to
;

-- 3. [Multiples JOINs] Let's discuss which associations are booking so that we can see which companies and industries are bringing more revenue to the areas hospitality market.

SELECT vips.member_id, vips.association , vips.assoc_type , hotels.hotel_name , hotels.hotel_id
FROM vips
FULL JOIN reservations
ON vips.member_id = reservations.member_id
LEFT JOIN hotels
ON reservations.hotel = hotels.hotel_id
WHERE vips.member_id <> 0 ;

-- 4. Let's send some gifts to all of the VIPs that have been members for the last 5 years or more. We'll send the gift to their dinner rsvp at their hotel.

SELECT vips.member_id, vips.last_name , r.dinner_rsvp , hotels.hotel_name
FROM vips
LEFT JOIN reservations AS r
ON vips.member_id = r.member_id
LEFT JOIN hotels
ON r.hotel = hotels.hotel_id
WHERE r.dinner_rsvp = 1;

-- 5. Get a list of all government-affiliated VIPs who have RSVP’d for dinner.
SELECT v.first_name, v.last_name, v.association
FROM vips v
JOIN reservations r ON v.member_id = r.member_id
WHERE v.assoc_type = 'government' AND r.dinner_rsvp = 1;









